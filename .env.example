# VaidyaAI Environment Configuration
# Copy this file to .env and fill in values

# ── Ollama settings ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
# Use 'vaidyaai' if you created the custom model:
# ollama create vaidyaai -f Modelfile

# ── Backend ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Docker Compose override (do not change unless running in container) ───────
# OLLAMA_BASE_URL=http://ollama:11434
